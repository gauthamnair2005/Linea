# Prime Number Checker
# Demonstrates conditionals and loops

var num = 17
var is_prime = 1
var i = 2

display "Checking if " + num + " is prime..."

for i from 2~num
  if (num % i) == 0
    is_prime = 0

if is_prime == 1
  display num + " is a prime number!"
else
  display num + " is not a prime number"
