# Linea HTTP Library
# Native implementation lives in linea-executor.

func http::get(url: string) -> any {
  return http::get(url)
}

func http::post(url: string, body: string) -> any {
  return http::post(url, body)
}

func http::request(method: string, url: string, headers: string, body: string) -> any {
  return http::request(method, url, headers, body)
}

func http::download(url: string, filepath: string) -> bool {
  return http::download(url, filepath)
}
