# Linea Math Library

func math::abs(x: int) -> int {
  if x < 0 {
    return 0 - x
  }
  return x
}

func math::max(a: int, b: int) -> int {
  if a > b {
    return a
  }
  return b
}

func math::min(a: int, b: int) -> int {
  if a < b {
    return a
  }
  return b
}

func math::factorial(n: int) -> int {
  if n <= 1 {
    return 1
  }
  return n * math::factorial(n - 1)
}

func math::isEven(x: int) -> bool {
  return x % 2 == 0
}

func math::isOdd(x: int) -> bool {
  return x % 2 != 0
}
