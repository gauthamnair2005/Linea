# Linea GUI Toolkit (compiled runtime backend)

func gui::window(title: string, message: string, width: int, height: int) -> bool {
  return gui::window(title, message, width, height)
}

func gui::buttonWindow(title: string, message: string, buttonLabel: string, width: int, height: int) -> bool {
  return gui::buttonWindow(title, message, buttonLabel, width, height)
}
