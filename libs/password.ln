# Linea Password/Security Library
# Native implementation lives in linea-executor.

func password::promptCli(message: string, mode: string) -> string {
  return password::promptCli(message, mode)
}

func password::promptGui(title: string) -> string {
  return password::promptGui(title)
}

func password::hash(secret: string) -> string {
  return password::hash(secret)
}

func password::verify(secret: string, stored: string) -> bool {
  return password::verify(secret, stored)
}
